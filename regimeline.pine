bearBD_Off_HiAdxMin = input.float(50.0, "Bear breakdown (HTF_OFF): high-ADX weak-close veto if ADX >= X", group=grpBear, step=1.0, minval=1.0)
bearBD_Off_HiAdx_CloseLocMax = input.float(0.20, "Bear breakdown (HTF_OFF): high-ADX weak-close veto if closeLoc > X", group=grpBear, step=0.01, minval=0.01, maxval=0.99)
bearBD_WeakCloseSlopeOn = input.bool(true, "Bear breakdown (HTF_OFF): veto middling close if ADX slope too weak", group=grpBear)
bearBD_WeakCloseLocMax = input.float(0.15, "Bear breakdown (HTF_OFF): weak-close threshold for slope veto", group=grpBear, step=0.01, minval=0.01, maxval=0.99)
bearBD_WeakCloseSlopeMin = input.float(3.00, "Bear breakdown (HTF_OFF): minimum ADX slope when closeLoc > threshold", group=grpBear, step=0.10)
bearBD_WeakCloseSlopeBandMax = input.float(0.19, "Bear breakdown (HTF_OFF): upper closeLoc bound for slope veto band", group=grpBear, step=0.01, minval=0.01, maxval=0.99)
bearBD_OffStretchWeakOn = input.bool(true, "Bear breakdown (HTF_OFF): veto stretched weak-slope breakdowns", group=grpBear)
bearBD_OffStretchWeak_CloseLocMin = input.float(0.30, "Bear breakdown (HTF_OFF): veto if closeLoc >=", group=grpBear, step=0.01, minval=0.01, maxval=0.99)
bearBD_OffStretchWeak_DistEFMin   = input.float(2.00, "Bear breakdown (HTF_OFF): veto if |close-EMAfast|/ATR >=", group=grpBear, step=0.05, minval=0.10)
bearBD_OffStretchWeak_AdxSlopeMax = input.float(1.60, "Bear breakdown (HTF_OFF): veto if ADX slope <=", group=grpBear, step=0.10)
bearMinBodyPct     = input.float(0.20, "Bear SHORT: breakdown candle body/range >=", group=grpBear, step=0.05)
bearBreakLookback  = input.int(9, "Bear SHORT: breakdown must break last N-bar low", group=grpBear, minval=3)

bearArmMaxBars     = input.int(14, "Bear SHORT: expire retest in N bars", group=grpBear, minval=3)
bearTS_Bars        = input.int(24, "Bear SHORT time-stop bars", group=grpBear, minval=5)
bearTS_MinMFE_ATR  = input.float(0.30, "Bear TS only if MFE < ATR*x", group=grpBear, step=0.05)
bearTS_ProgOn          = input.bool(true, "Bear TS: progressive early exit", group=grpBear)
bearTS_Chk1_Bars       = input.int(14, "Bear TS: checkpoint 1 bars", group=grpBear, minval=5)
