bearShortCloseNearLo = input.float(0.35, "Bear SHORT: close must be in bottom X of range", group=grpBear, step=0.05)
bearAcceptEntryOn = input.bool(true, "Bear: allow entry on acceptance-down (no retest)", group=grpBear)

bearExitUseReclaim = input.bool(true,  "Bear short: exit on LTF reclaim (pre HTF-BULL-KILL)", group=grpBear)
bearExitReclaimBars = input.int(2,     "Bear short: reclaim closes needed",                  group=grpBear, minval=1)
bearExitUseEmaReclaim = input.bool(true, "Bear short: EMAfast reclaim counts as reclaim",    group=grpBear)
bearBreakMaxDistEFATR = input.float(2.6, "Bear breakdown: max |close-EMAfast| (ATR)", group=grpBear, step=0.1, minval=0.1)
bearBD_FailExitOn       = input.bool(true, "Bear breakdown: early fail exit on reclaim pulses", group=grpBear)
bearBD_FailWinBars      = input.int(28, "Bear breakdown: early-fail window bars", group=grpBear, minval=1)
bearBD_FailPulseHits    = input.int(2, "Bear breakdown: reclaim pulses to fail", group=grpBear, minval=1, maxval=10)
bearBD_FailNeedEMA      = input.bool(true, "Bear breakdown: reclaim pulse must also close above EMAfast", group=grpBear)
