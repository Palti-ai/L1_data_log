// Defer resets until we are truly flat (calc_on_every_tick safety)
var bool pendingReset = false
var bool bearForceCloseShort = false

bool bearBD_Pos = inPos and isShort and (posTag == "BEAR") and not na(bearReclLvlPos)

bool bearBD_ReclaimAgainstPos =
     bearBD_Pos and
     (
         (not na(bearReclLvlPos) and close > bearReclLvlPos) or
         (bearBD_ReclaimExitUseEma and not na(bearEmaFastPos) and close > bearEmaFastPos)
     )

if barstate.isconfirmed
    bearReclaimCloseCnt :=
         bearBD_ReclaimAgainstPos ? (nz(bearReclaimCloseCnt[1]) + 1) : 0
else
    bearReclaimCloseCnt := nz(bearReclaimCloseCnt[1])

//====================================================
// BEAR structural reclaim invalidation
// Applies to BOTH:
// 1) breakdown shorts
// 2) accept shorts
// Exit only BEFORE TP0, so winners that already paid are not disturbed.
//====================================================

// Keep your existing breakdown archetype check.
// Add the equivalent accept-archetype check using your current bearEntryArch constants.
bool bearIsBreakdownShort = inPos and posTag == "BEAR" and bearEntryArch == 0
bool bearIsAcceptShort    = inPos and posTag == "BEAR" and bearEntryArch == 1

float bearReclaimRef = na
bearReclaimRef := math.max(
     nz(bearReclLvlPos, bearReclLvl),
     nz(bearEmaFastPos, emaFast)
)

// Structural failure = accepted reclaim back above the short-failure reference.
// Use confirmed closes only.
bool bearReclaimCloseNow =
     inPos and posTag == "BEAR" and (not bearTP0Done) and
     not na(bearReclaimRef) and close > bearReclaimRef

if inPos and posTag == "BEAR" and (not bearTP0Done) and (bearIsBreakdownShort or bearIsAcceptShort)
    bearReclaimCloseCnt := bearReclaimCloseNow ? (nz(bearReclaimCloseCnt[1]) + 1) : 0
else
    bearReclaimCloseCnt := 0

bool bearBD_ReclaimExitNow  = bearIsBreakdownShort and bearReclaimCloseCnt >= 2
bool bearACC_ReclaimExitNow = bearIsAcceptShort    and bearReclaimCloseCnt >= 2

//bool bearBD_ReclaimExitNow =
//     bearBD_Pos and
//     (not bearBD_ReclaimExitPreTP0Only or not bearTP0Done) and
//     (bearReclaimCloseCnt >= bearBD_ReclaimExitCloses)
     

