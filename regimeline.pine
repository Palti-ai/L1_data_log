bearBD_PreTP0TimeoutOn   = input.bool(true, "Bear breakdown: pre-TP0 timeout exit", group=grpBear)
bearBD_PreTP0TimeoutBars = input.int(28, "Bear breakdown: exit if TP0 not reached within N bars", group=grpBear, minval=5)
bearPreTP0StaleOn        = input.bool(true, "Bear short: pre-TP0 stale/non-performance exit", group=grpBear)
bearPreTP0StaleBars      = input.int(18, "Bear short: stale check after N bars", group=grpBear, minval=5)
