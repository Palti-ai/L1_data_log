bearBD_ChaseExh_RngAtrMin  = input.float(1.40, "Bear SHORT breakdown: veto if entry candle range/ATR >= X (exhaustion)", group=grpBear, step=0.05)
bearBD_ChaseExh_DistEFMin  = input.float(2.20, "Bear SHORT breakdown: veto if dist-to-EMAfast/ATR >= X (chase)",      group=grpBear, step=0.05)
bearBD_ChaseExh_ConfirmBars  = input.int(2, "Bear breakdown: if chase+exh, require N confirm closes", group=grpBear, minval=1, maxval=3)
bearBD_ChaseExh_ConfirmLowLB = input.int(2, "Bear breakdown: confirm uses lowest(low, N) break",      group=grpBear, minval=1, maxval=5)
bearBD_WeakDriftOn         = input.bool(true,  "Bear weak-drift veto", group=grpBear)
bearBD_WeakDrift_RngAtrMax = input.float(0.50, "Bear weak-drift: max range ATR", group=grpBear, step=0.05)
bearBD_WeakDrift_DistEFMin = input.float(1.90, "Bear weak-drift: min dist EF ATR", group=grpBear, step=0.05)
bearBD_WeakDrift_BodyPctMax= input.float(0.55, "Bear weak-drift: max body %", group=grpBear, step=0.05)
